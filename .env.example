# PydanticAI Gateway configuration
# Get your API key from https://app.pydantic.dev/
PYDANTIC_AI_GATEWAY_API_KEY=pylf_v1_us_your_key_here

# Model to use (gateway/{provider}:{model})
# See https://ai.pydantic.dev/models/
MODEL=gateway/anthropic:claude-sonnet-4-5

# Pipeline settings (optional)
BATCH_SIZE=20
MAX_CONCURRENT=5
# Glob pattern for which PDFs to process (default: all)
PDF_GLOB=*.pdf
